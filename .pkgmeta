# Use manual changelog instead of auto-generated from git commits
manual-changelog: CHANGELOG.md

# Files to exclude from the final packaged .zip
ignore:
  - .agent/
  - .antigravityrules
  - .claude/
  - .github/
  - .gitignore
  - .pkgmeta
  - AGENTS.md
  - CLAUDE.md
  - README.md
  - tests.xml
  - wiki/
  # CodeSight dev tooling — versioned in git, never shipped to CurseForge
  - .codesight/
  - .codesightignore
  - .mcp.json
  - node_modules/
  - package.json
  - package-lock.json
  - patches/